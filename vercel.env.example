# Vercel environment variables example — copy these into your Vercel Project > Settings > Environment Variables
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=parasara-1f81c.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=parasara-1f81c
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=251317464877
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXX

# Comma-separated providers. Enable Google provider in Firebase Console.
VITE_FIREBASE_SIGN_IN_PROVIDERS=google,email

# Also add your site domain to Firebase Console > Authentication > Authorized domains:
# poster-swart-ten.vercel.app
# and for local dev: 127.0.0.1 or localhost
