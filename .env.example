PORT=5050
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/connectpro_nexus
JWT_SECRET=replace-this-with-a-long-random-secret
CLIENT_ORIGIN=http://127.0.0.1:5174
# Set this in frontend-only deployments, for example:
# VITE_API_BASE_URL=https://your-backend.example.com
VITE_API_BASE_URL=
# Local browser-only auth for demos/frontend-only deployments. Set false when backend auth is ready.
VITE_LOCAL_AUTH=true
# Optional FirebaseUI auth. Add values from Firebase Console > Project settings > Web app config.
# Enable the matching providers in Firebase Console > Authentication > Sign-in method.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Comma-separated: google,email,phone,facebook,twitter,github
VITE_FIREBASE_SIGN_IN_PROVIDERS=google,email
RATE_LIMIT=1000
INITIAL_BUSINESS_NAME=
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
INITIAL_INDUSTRY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
UPI_MERCHANT_VPA=
UPI_MERCHANT_NAME=Parasara
# Optional local-only bypass for development demos. Leave false/empty for real payments.
ENABLE_LOCAL_CHECKOUT=false
RESEND_API_KEY=
# Optional local-only bypass for development when RESEND_API_KEY is unavailable.
ENABLE_DEV_AUTH_TOKENS=false
EMAIL_FROM=Parasara <no-reply@example.com>
