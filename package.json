{
  "name": "parasara",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite --host 127.0.0.1 --port 5174 --strictPort",
    "mobile": "concurrently \"npm run server\" \"vite --host 0.0.0.0 --port 5174 --strictPort\"",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "seed": "node server/seed.js",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "check": "node --check server/index.js && node --check server/seed.js",
    "test:api": "node scripts/api-smoke.js",
    "migrate": "node scripts/migrate.js",
    "jobs": "node scripts/jobs.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^22.1.1",
    "vite": "^8.0.14"
  }
}
